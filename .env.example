# DMAIC Coach configuration
# The default provider is "mock": fully deterministic, no API key, no network.
# Switch to a live LLM only if you want natural-language voice on top of the
# (already deterministic) coaching, retrieval and grading.
LLM_PROVIDER=mock

# Optional live providers (uncomment one + set the matching key):
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# LLM_PROVIDER=grok
# XAI_API_KEY=xai-...

# Embeddings backend: "local" (default, offline, no download) or "fastembed".
EMBEDDER=local
